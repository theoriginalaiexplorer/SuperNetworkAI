<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= it.title ?? "Ollama3D" %></title>

  <!-- Bootstrap 5 CSS only (no Bootstrap JS) -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />

  <!-- Built client-side assets (includes HTMX, Alpine.js and stores) -->
  <script src="/public/assets/main-BHib6PCM.js" defer></script>

  <!-- HTMX debug + Loading Event Handlers -->
  <script>
    // Debug: confirm HTMX loaded (check after defer scripts execute)
    window.addEventListener('load', function() {
      console.log('[HTMX] loaded:', typeof htmx !== 'undefined' ? 'YES v' + htmx.version : 'NO — missing from bundle');
    });

    document.addEventListener('htmx:beforeRequest', function(e) {
      console.log('[HTMX] beforeRequest', e.detail.requestConfig.verb.toUpperCase(), e.detail.requestConfig.path);
      if (window.Alpine && Alpine.store('loading')) {
        Alpine.store('loading').startLoading('Loading...');
      }
    });
    document.addEventListener('htmx:afterRequest', function(e) {
      console.log('[HTMX] afterRequest status=' + e.detail.xhr.status, 'path=' + e.detail.pathInfo?.requestPath);
      if (window.Alpine && Alpine.store('loading')) {
        Alpine.store('loading').stopLoading();
      }
    });
    document.addEventListener('htmx:responseError', function(e) {
      console.error('[HTMX] responseError status=' + e.detail.xhr.status, e.detail);
      if (window.Alpine && Alpine.store('loading')) {
        Alpine.store('loading').stopLoading();
      }
    });
    document.addEventListener('htmx:sendError', function(e) {
      console.error('[HTMX] sendError — could not reach server', e.detail);
    });
    document.addEventListener('htmx:beforeSwap', function(e) {
      console.log('[HTMX] beforeSwap status=' + e.detail.xhr.status, 'isError=' + e.detail.isError);
    });
  </script>
</head>
<body>
  <%~ it.body %>
  
  <!-- Loading Overlay (disabled temporarily for testing) -->
  <!--
  <div
    x-cloak
    class="position-fixed top-0 left-0 w-100 h-100 d-flex justify-content-center align-items-center bg-dark bg-opacity-50"
    style="z-index: 9999;"
    x-show="$store.loading.isLoading"
    id="loading-overlay"
  >
    <div class="card text-center" style="min-width: 300px;">
      <div class="card-body p-4">
        <div class="spinner-border" style="
          width: 3rem;
          height: 3rem;
          border: 4px solid rgba(255,255,255,0.25);
          border-radius: 50%;
          border-top-color: var(--bs-primary);
          animation: spin 1.2s linear infinite;
        ">
        </div>
        <p class="mb-3 text-white"><span x-text="$store.loading.message">Loading...</span></p>
      </div>
    </div>
  </div>
  -->

  <style>
    @keyframes spin {
      0% { transform: rotate(360deg); }
      100% { transform: rotate(360deg); }
    }
    .spinner-border {
      border: 4px solid;
      border-top-color: var(--bs-primary);
      border-right: 2px solid transparent;
      border-radius: 50%;
    }
    [x-cloak] { display: none !important; }
  </style>
</body>
</html>

# Copy to .env and fill in values before running locally.

# Server
PORT=3001

# Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=[service-role-key]

# AI / LLM
GROQ_API_KEY=[your-groq-api-key]

# Embeddings — use "ollama" for local dev, "nomic" for prod
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
NOMIC_API_KEY=[your-nomic-api-key]

# Security
WS_TOKEN_SECRET=[random-32-byte-hex]
INTERNAL_API_SECRET=[random-32-byte-hex]

# File uploads
UPLOADTHING_SECRET=[your-uploadthing-secret]

# BFF origin (for CORS)
BFF_ORIGIN=http://localhost:3000
